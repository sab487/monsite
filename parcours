<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Parcours | Sabrina Askour</title>
    <style>
        :root {
            --color-text-primary: #1a1a1a;
            --color-text-secondary: #4a4a4a;
            --color-border-tertiary: #e1e1e1;
            --color-background-primary: #ffffff;
            --blue-main: #3b8fd4;
            --blue-light: #e8f4fd;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #fcfcfc; color: var(--color-text-primary); line-height: 1.6; }

        /* Navigation */
        nav {
            display: flex; justify-content: center; padding: 20px 5%; 
            border-bottom: 0.5px solid var(--color-border-tertiary);
            background: #fff; position: sticky; top: 0; z-index: 100;
        }
        .nav-links { display: flex; gap: 10px; }
        .nav-links a {
            font-size: 13px; text-decoration: none; color: var(--color-text-primary);
            padding: 8px 16px; border-radius: 25px; border: 1px solid #1a1a1a; transition: 0.3s;
        }
        .nav-links a.active { background: var(--blue-light); border-color: var(--blue-main); color: var(--blue-main); font-weight: 600; }

        .container { max-width: 1100px; margin: 0 auto; padding: 60px 20px; }
        h1 { font-size: 32px; margin-bottom: 40px; text-align: center; }
        h2 { font-size: 24px; margin: 40px 0 20px; color: var(--blue-main); border-bottom: 2px solid var(--blue-light); display: inline-block; }

        /* Style Timeline Scolaire */
        .timeline { border-left: 3px solid var(--blue-main); padding-left: 30px; margin-left: 20px; }
        .timeline-item { position: relative; margin-bottom: 40px; }
        .timeline-item::before {
            content: ""; position: absolute; left: -38px; top: 5px;
            width: 12px; height: 12px; background: white; border: 3px solid var(--blue-main); border-radius: 50%;
        }
        .year { font-weight: 700; color: var(--blue-main); font-size: 14px; }
        .school-name { font-weight: 700; font-size: 18px; margin: 5px 0; }
        .diploma { font-style: italic; color: var(--color-text-secondary); }

        /* Grille Ecoles & Entreprises */
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 20px; }
        .card { 
            background: white; border: 1px solid var(--color-border-tertiary); 
            border-radius: 12px; padding: 25px; transition: 0.3s;
            display: flex; flex-direction: column; align-items: center; text-align: center;
        }
        .card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
        .card img { height: 60px; margin-bottom: 20px; object-fit: contain; }
        .card h3 { font-size: 16px; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 1px; }
        .card p { font-size: 14px; color: var(--color-text-secondary); text-align: justify; }

        @media (max-width: 768px) { .grid { grid-template-columns: 1fr; } }
    </style>
</head>
